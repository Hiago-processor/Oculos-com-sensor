// Óculos sensor para deficientes visuais
// Hardware: Arduino Uno + HC-SR04 + Motor de vibração 5V

#define PINO_TRIG    9   // HC-SR04 → pino TRIG
#define PINO_ECHO   10   // HC-SR04 → pino ECHO
#define PINO_MOTOR  11   // Motor vibração (PWM)

void setup() {
  pinMode(PINO_TRIG, OUTPUT);
  pinMode(PINO_ECHO, INPUT);
  pinMode(PINO_MOTOR, OUTPUT);
  Serial.begin(9600);
}

long medirDistancia() {
  digitalWrite(PINO_TRIG, LOW);
  delayMicroseconds(2);
  digitalWrite(PINO_TRIG, HIGH);
  delayMicroseconds(10);
  digitalWrite(PINO_TRIG, LOW);

  long duracao = pulseIn(PINO_ECHO, HIGH, 30000); // timeout 30ms
  long distancia = duracao * 0.034 / 2;
  return distancia;
}

void vibrar(int intensidade, int duracao) {
  analogWrite(PINO_MOTOR, intensidade); // 0–255
  delay(duracao);
  analogWrite(PINO_MOTOR, 0);
}

void loop() {
  long distancia = medirDistancia();

  Serial.print("Distancia: ");
  Serial.print(distancia);
  Serial.println(" cm");

  if (distancia > 0 && distancia < 30) {
    // Muito perto → vibração forte e contínua
    analogWrite(PINO_MOTOR, 255);
    delay(80);
    analogWrite(PINO_MOTOR, 0);
    delay(40);

  } else if (distancia < 80) {
    // Perto → pulsos médios
    vibrar(200, 100);
    delay(200);

  } else if (distancia < 150) {
    // Moderado → pulso leve
    vibrar(120, 80);
    delay(500);

  } else {
    // Livre → motor desligado
    analogWrite(PINO_MOTOR, 0);
    delay(200);
  }
}
